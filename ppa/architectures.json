      "rtl_file": "snn_network.v",
      "synth_parameters": {},
      "sim_parameters": {
        "W_BITS": 2,
        "TRACE_BITS": 2,
        "TRIPLET_EN": 0,
        "LEAK_EN": 0
      },
      "make_target": "ablation-original"
    },
    "pair": {
      "label": "Pair",
      "group": "baseline",
      "description": "Extended pair STDP (4-bit weights, LIF neurons, asymmetric)",
      "rtl_file": "snn_dynamic.v",
      "synth_parameters": {
        "TRIPLET_EN": 0,
        "LEAK_EN": 1,
        "W_BITS": 4,
        "MODE": 0
      },
      "sim_parameters": {
        "TRIPLET_EN": 0
      },
      "make_target": "ablation-pair"
    },
    "triplet": {
      "label": "Triplet",
      "group": "baseline",
      "description": "Triplet STDP (4-bit weights, LIF neurons, asymmetric)",
      "rtl_file": "snn_dynamic.v",
      "synth_parameters": {
        "TRIPLET_EN": 1,
        "LEAK_EN": 1,
        "W_BITS": 4,
        "MODE": 0
      },
      "sim_parameters": {},
      "make_target": "ablation-triplet"
    },
    "triplet_optimized": {
      "label": "Triplet Optimized",
