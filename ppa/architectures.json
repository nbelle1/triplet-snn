      "sim_parameters": {
        "SPIKE_GATE_EN": 1,
        "LUT_STDP_EN": 1
      },
      "verilog_include_dirs": ["../../lut"],
      "verilog_defines": ["LUT_STDP_EN_FLAG"],
      "make_target": null
    }
