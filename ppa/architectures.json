      "sim_parameters": {
        "SEG_ADDER_EN": 1
      },
      "make_target": null
    },
    "triplet_optimized_lut_stdp": {
      "label": "Triplet Opt. LUT-STDP",
      "group": "optimized",
      "description": "Optimized triplet with LUT-based STDP weight updates (ROM replaces multipliers)",
      "rtl_file": "snn_dynamic_optimized.v",
