      "rtl_file": "snn_dynamic_optimized.v",
      "synth_parameters": {
        "TRIPLET_EN": 1,
        "LEAK_EN": 1,
        "W_BITS": 4,
        "MODE": 0,
        "SPIKE_GATE_EN": 0
      },
      "sim_parameters": {},
      "make_target": null
    },
    "triplet_optimized_spike_gated": {
      "label": "Triplet Opt. Spike-Gated",
      "group": "optimized",
      "description": "Optimized triplet with spike-gated clock enable",
      "rtl_file": "snn_dynamic_optimized.v",
      "synth_parameters": {
        "TRIPLET_EN": 1,
        "LEAK_EN": 1,
        "W_BITS": 4,
        "MODE": 0,
        "SPIKE_GATE_EN": 1
      },
      "sim_parameters": {
        "SPIKE_GATE_EN": 1
      },
      "make_target": null
    },
    "triplet_optimized_nn": {
      "label": "Triplet Opt. Nearest-Neighbor",
      "group": "optimized",
      "description": "Optimized triplet with nearest-neighbor trace mode",
      "rtl_file": "snn_dynamic_optimized.v",
      "synth_parameters": {
        "TRIPLET_EN": 1,
        "LEAK_EN": 1,
        "W_BITS": 4,
        "MODE": 1
      },
      "sim_parameters": {
        "MODE": 1
      },
      "make_target": null
    },
    "triplet_optimized_seg_adder": {
      "label": "Triplet Opt. Seg. Adder",
      "group": "optimized",
      "description": "Optimized triplet with approximate segmented adder for weighted sum",
      "rtl_file": "snn_dynamic_optimized.v",
      "synth_parameters": {
        "TRIPLET_EN": 1,
        "LEAK_EN": 1,
        "W_BITS": 4,
        "MODE": 0,
        "SEG_ADDER_EN": 1
